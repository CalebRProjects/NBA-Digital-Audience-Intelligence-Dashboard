  <dashboards>
    <dashboard enable-sort-zone-taborder='true' name='Content &amp; Audience Response'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Tableau Semibold'>&lt;Sheet Name&gt;</run>
