      </layout-options>
      <repository-location derived-from='https://public.tableau.com/workbooks/NBADigitalAudienceIntelligenceDashboard/ContentAudienceResponse?rev=' id='130900359' path='/workbooks/NBADigitalAudienceIntelligenceDashboard' revision='' />
      <style />
      <size sizing-mode='automatic' />
      <zones>
        <zone h='100000' id='4' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98476' id='5' param='vert' type-v2='layout-flow' w='99166' x='417' y='762'>
            <zone fixed-size='59' h='6381' id='7' is-fixed='true' type-v2='title' w='99166' x='417' y='762'>
              <zone-style>
