      <column caption='Monitoring Priority Short' datatype='string' name='[Calculation_1343063721033728]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [monitoring_priority] = &quot;High Engagement / High Negative Sentiment&quot; THEN &quot;High Eng. + High Neg.&quot;&#13;&#10;ELSEIF [monitoring_priority] = &quot;High Negative Sentiment&quot; THEN &quot;High Neg. Sentiment&quot;&#13;&#10;ELSEIF [monitoring_priority] = &quot;High Engagement&quot; THEN &quot;High Engagement&quot;&#13;&#10;ELSE &quot;Standard&quot;&#13;&#10;END' />
